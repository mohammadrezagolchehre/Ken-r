# Kenâr infra environment — copy to .env and fill in. NEVER commit .env.

# --- Postgres ---
POSTGRES_USER=kenar
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=kenar
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=change-me-strong
REDIS_PORT=6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=kenar
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Backend ---
BACKEND_PORT=8080

# --- SMS provider (phone OTP). Default Kavenegar (Iranian). ---
KENAR_SMS_PROVIDER=kavenegar
KENAR_KAVENEGAR_API_KEY=

# --- Push provider (device wake). Pushe (Iranian, FCM-independent). ---
KENAR_PUSH_PROVIDER=pushe
KENAR_PUSHE_TOKEN=
