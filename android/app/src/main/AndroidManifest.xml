<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".KenarApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.Kenar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Kenar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AndroidX per-app locale support (in-app language switch). -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <!-- Mood widget — first end-to-end vertical slice (Jetpack Glance). -->
        <receiver
            android:name=".widget.mood.MoodWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/mood_widget_info" />
        </receiver>

        <!-- Love Tap widget — quick affectionate taps + tap-back loop. -->
        <receiver
            android:name=".widget.lovetap.LoveTapWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/love_tap_widget_info" />
        </receiver>

        <!-- Shared Drawing widget — passive renderer for partner sketches. -->
        <receiver
            android:name=".widget.drawing.DrawingWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/drawing_widget_info" />
        </receiver>

        <!-- Shared Photo widget — passive renderer for cached moment photos. -->
        <receiver
            android:name=".widget.photo.PhotoWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/photo_widget_info" />
        </receiver>

        <!-- Countdown widget — passive shared-date snapshot renderer. -->
        <receiver
            android:name=".widget.countdown.CountdownWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/countdown_widget_info" />
        </receiver>

        <!-- Their World widget — partner time/weather/day-night snapshot. -->
        <receiver
            android:name=".widget.world.TheirWorldWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/their_world_widget_info" />
        </receiver>
    </application>
</manifest>
